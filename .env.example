# Database Configuration
DATABASE_URL=postgresql://payflow_user:secure_password@localhost:5432/payflow_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=payflow_db
DATABASE_USER=payflow_user
DATABASE_PASSWORD=secure_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-this
TOKEN_VAULT_SECRET=another-32-char-secret-for-vault

# AI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4-turbo-preview
USE_LOCAL_LLM=false
LOCAL_LLM_ENDPOINT=http://localhost:11434

# Payment Gateway Settings
GATEWAY_NAME=PayFlow
MERCHANT_ID=merchant_demo_001
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT_MS=5000

# Ghost Detection Settings
GHOST_DETECTION_INTERVAL_MS=30000
GHOST_TIMEOUT_THRESHOLD_MS=300000
GHOST_SCORE_THRESHOLD=70

# Feature Flags
ENABLE_ML_DETECTION=true
ENABLE_AI_AUDITOR=true
ENABLE_WEBHOOK_SIGNING=true

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Development
DEBUG=payflow:*
LOG_LEVEL=debug
